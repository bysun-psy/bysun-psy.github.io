/* ── UTILS ── */
type AppItem = {
  id: number; name: string; useId: number; space: string; group: string; cell: string;
  qty: number; min: number|null; spec: string; note: string; received: string;
  createdAt: string; updatedAt: string; updatedBy: string;
}

function itemsByLoc(items: AppItem[]) {
  const m: Record<string, AppItem[]> = {}
  items.forEach(it=>{const k=`${it.space}/${it.group}/${it.cell}`;(m[k]=m[k]||[]).push(it)})
  return m
}
function dominant(its: AppItem[]) {
  if(!its||!its.length) return null
  const c: Record<number,number> = {}
  its.forEach(it=>{c[it.useId]=(c[it.useId]||0)+1})
  return useById(+Object.entries(c).sort((a,b)=>+b[1]-+a[1])[0][0])
}
function hi(text: string, q: string) {
  if(!q) return text
  const i=text.toLowerCase().indexOf(q.toLowerCase())
  if(i<0) return text
  return <>{text.slice(0,i)}<mark style={{background:'var(--tint-yellow)',color:'var(--ink)',padding:'0 1px',borderRadius:2}}>{text.slice(i,i+q.length)}</mark>{text.slice(i+q.length)}</>
}


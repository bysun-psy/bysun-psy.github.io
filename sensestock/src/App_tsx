type FormData = {
  name:string; useId:number|null; space:string; group:string; cell:string;
  spec:string; qty:string|number; min:string|number|null; received:string; note:string; id?:number;
}
function blank(pre: Partial<FormData>={}): FormData {
  return {name:'',useId:pre.useId||null,space:pre.space||'',group:pre.group||'',cell:pre.cell||'',spec:'',qty:'',min:'',received:'',note:''}
}

function RegisterEdit({mode,item,prefill,onCancel,onSave,onDelete}: {
  mode:'create'|'edit', item?:AppItem, prefill?:Partial<FormData>|null,
  onCancel:()=>void, onSave:(data:Record<string,unknown>)=>Promise<void>, onDelete?:(id:number)=>void
}) {
  const isEdit=mode==='edit'
  const [form,setForm]=useState<FormData>(()=>isEdit&&item?{...item,useId:item.useId,qty:item.qty,min:item.min??''}:blank(prefill||{}))
  const [ef,setEf]=useState<string|null>(null)
  const [errs,setErrs]=useState<Record<string,string>>({})
  const [delM,setDelM]=useState(false)
  const [saving,setSaving]=useState(false)
  const [saved,setSaved]=useState(false)
  const rq=form.useId!=null&&QTY_REQ.includes(form.useId)
  const setF=(k:string,v:unknown)=>{
    setForm(f=>{const n={...f,[k]:v};if(k==='space'){(n as FormData).group='';(n as FormData).cell='';}if(k==='group')(n as FormData).cell='';return n as FormData})
    setEf(k)
  }
  const validate=()=>{
    const e: Record<string,string>={}
    if(!form.name.trim())e.name='품목명을 입력하세요.'
    if(!form.useId)e.useId='용도를 선택하세요.'
    if(!form.space)e.space='공간을 선택하세요.'
    if(!form.group)e.group='구역을 선택하세요.'
    if(!form.cell)e.cell='셀을 선택하세요.'
    if(rq){if(form.qty==='')e.qty='수량은 필수입니다.';if(form.min==='')e.min='최소 재고는 필수입니다.'}
    setErrs(e);return !Object.keys(e).length
  }
  const submit=async()=>{
    if(!validate()) return
    setSaving(true)
    try {
      await onSave({...form,id:item?.id,qty:form.qty===''?0:+form.qty,min:form.min===''||form.min===null?null:+form.min})
      setSaved(true); setTimeout(()=>setSaved(false),1200)
    } finally { setSaving(false) }
  }
  const groups=form.space?[...new Set((ZONES[form.space]||[]).map(z=>z.group))]:[]
  const cells=form.space&&form.group?(ZONES[form.space]||[]).filter(z=>z.group===form.group).flatMap(z=>z.cells):[]
  return (
    <div className="col" style={{height:'100%'}}>
      <Topbar title={isEdit?'품목 수정':'신규 등록'} sub={isEdit&&item?`최종 수정: ${item.updatedAt} · ${item.updatedBy}`:'비품 정보를 입력하세요'} action={
        <div className="row" style={{gap:8}}>
          {isEdit&&<button className="btn btn-danger" onClick={()=>setDelM(true)}><IC.trash/> 삭제</button>}
          <button className="btn btn-secondary" onClick={onCancel}>취소</button>
          <button className="btn btn-primary" onClick={submit} disabled={saving}>{saving?'저장 중...':(isEdit?'저장':'등록')}</button>

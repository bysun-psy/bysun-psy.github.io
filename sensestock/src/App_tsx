/* ── APP ── */
type Route = {name:string, itemId?:number, space?:string, group?:string, cell?:string, fromSpace?:string}

export default function App() {
  const { user: authUser, loading: authLoading, login, logout } = useAuth()
  const { items, activity, loading: itemsLoading, upsertItem, deleteItem, deleteItems } = useItems()
  const [appUser, setAppUser] = useState<{name:string,email:string}|null>(null)
  const [route, setRoute] = useState<Route>({name:'dashboard'})

  // authUser가 바뀌면 appUser 동기화
  useEffect(()=>{
    if(authUser){
      const name = authUser.user_metadata?.name || authUser.email?.split('@')[0] || '사용자'
      setAppUser({name, email: authUser.email||''})
    } else {
      setAppUser(null)
    }
  },[authUser])

  const nav=(name:string, params: Partial<Route>={})=>setRoute({name,...params})
  const openItem=(it:AppItem, fromSpace?: string)=>{
    if(it&&it.id!=null) setRoute({name:'detail',itemId:it.id,fromSpace})
  }

  const handleLogin = async (u:{name:string,email:string}) => {
    setAppUser(u)
    setRoute({name:'dashboard'})
  }

  const handleLogout = async () => {
    await logout()
    setAppUser(null)
  }

  const handleSave = async (data: Record<string,unknown>) => {
    if(!appUser) return
    const saved = await upsertItem(data, appUser.name)
    const savedId = saved?.id ?? (data.id as number)
    setRoute({name:'detail', itemId: savedId, fromSpace: route.fromSpace})
  }

  const handleDelete = async (id: number) => {
    if(!appUser) return
    const it = items.find(i=>i.id===id)
    if(it) await deleteItem(id, it.name, appUser.name)
    nav('search')
  }

  const handleDeleteMany = async (ids: number[]) => {
    await deleteItems(ids)
  }

  if(authLoading) return (
    <>
      <style>{SIDEBAR_CSS}{STYLE_SHEET}</style>
      <div className="app"><LoadingScreen/></div>
    </>
  )

  if(!authUser || !appUser) return (
    <>
      <style>{SIDEBAR_CSS}{STYLE_SHEET}</style>
      <div className="app"><Login onLogin={handleLogin}/></div>
    </>
  )

  if(itemsLoading) return (
    <>
      <style>{SIDEBAR_CSS}{STYLE_SHEET}</style>
      <div className="app"><LoadingScreen/></div>
    </>
  )

  const getItem=(id:number)=>items.find(i=>i.id===id)||null

  let view: React.ReactNode = null
  if(route.name==='dashboard'){
    view=<Dashboard items={items} activity={activity} onNav={nav}/>
  } else if(route.name==='search'){
    view=<Search items={items} onItemClick={openItem} onDelete={handleDeleteMany}/>
  } else if(route.name==='space'){
    view=<SpaceView items={items} initialSpace={route.space} onNav={nav} onItemClick={(it,fromSpace)=>openItem(it,fromSpace)}/>
  } else if(route.name==='register'){
    view=<RegisterEdit
      mode="create"
      prefill={route.group?{space:route.space,group:route.group,cell:route.cell}:null}
      onCancel={()=>route.space?nav('space',{space:route.space}):nav('search')}
      onSave={handleSave}
    />
  } else if(route.name==='edit'){
    const it=getItem(route.itemId!)
    view=it
      ?<RegisterEdit mode="edit" item={it} onCancel={()=>setRoute({name:'detail',itemId:it.id,fromSpace:route.fromSpace})} onSave={handleSave} onDelete={handleDelete}/>
      :<Search items={items} onItemClick={openItem} onDelete={handleDeleteMany}/>
  } else if(route.name==='detail'){
    const it=getItem(route.itemId!)
    view=it
      ?<ItemDetail
          item={it}
          onBack={()=>route.fromSpace?nav('space',{space:route.fromSpace}):nav('search')}
          onEdit={()=>setRoute({name:'edit',itemId:it.id,fromSpace:route.fromSpace})}
          onDelete={handleDelete}
        />
      :<Search items={items} onItemClick={openItem} onDelete={handleDeleteMany}/>
  }

  return (
    <>
      <style>{SIDEBAR_CSS}{STYLE_SHEET}</style>
      <div className="app" style={{display:'flex'}}>
        <Sidebar cur={route.name} onNav={nav} user={appUser} onLogout={handleLogout}/>
        <div style={{flex:1,display:'flex',flexDirection:'column',minWidth:0,height:'100vh',overflow:'hidden'}}>
          {view}
        </div>
      </div>
    </>
  )
}
